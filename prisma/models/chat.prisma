model Conversation {
    id         Int      @id @default(autoincrement())
    orderId    Int
    customerId Int
    sellerId   Int
    customer   User     @relation("CustomerConversations", fields: [customerId], references: [id])
    seller     User     @relation("SellerConversations", fields: [sellerId], references: [id])
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    messages Message[]

    @@unique([orderId, customerId, sellerId])
    @@index([customerId]) 
    @@index([sellerId])
}

model Message {
    id             Int          @id @default(autoincrement())
    conversationId Int
    conversation   Conversation @relation(fields: [conversationId], references: [id])
    senderId       Int
    sender         User         @relation("ChatMessages", fields: [senderId], references: [id])
    content        String       @db.Text
    
    createdAt      DateTime     @default(now())
    updatedAt      DateTime     @updatedAt

    @@index([senderId])
}
