<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Reset Password</title>
</head>

<body style="margin:0; padding:0; background-color:#f4f6f8; font-family:Arial, sans-serif;">
  
  <table width="100%" cellpadding="0" cellspacing="0" style="padding:40px 0;">
    <tr>
      <td align="center">

        <!-- Card -->
        <table width="420" cellpadding="0" cellspacing="0" 
          style="background:#ffffff; border-radius:12px; padding:30px; box-shadow:0 4px 20px rgba(0,0,0,0.08);">

          <!-- Header -->
          <tr>
            <td align="center" style="padding-bottom:20px;">
              <h2 style="margin:0; color:#111827;">🔐 Password Reset</h2>
              <p style="color:#6b7280; font-size:14px; margin-top:8px;">
                Here is your temporary password
              </p>
            </td>
          </tr>

          <!-- Divider -->
          <tr>
            <td style="border-top:1px solid #e5e7eb; padding-top:20px;"></td>
          </tr>

          <!-- Content -->
          <tr>
            <td align="center" style="padding:20px 0;">
              <p style="color:#374151; font-size:14px; margin-bottom:12px;">
                Your default password is:
              </p>

              <!-- Password Box -->
              <div style="
                display:inline-block;
                padding:12px 20px;
                background:#111827;
                color:#ffffff;
                font-size:18px;
                font-weight:bold;
                border-radius:8px;
                letter-spacing:1px;
              ">
                {{defaultPassword}}
              </div>
            </td>
          </tr>

          <!-- Warning -->
          <tr>
            <td align="center" style="padding-top:10px;">
              <p style="color:#ef4444; font-size:13px; margin:0;">
                ⚠ Please change your password after logging in
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" style="padding-top:30px;">
              <p style="color:#9ca3af; font-size:12px;">
                If you didn’t request this, please ignore this email.
              </p>
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>